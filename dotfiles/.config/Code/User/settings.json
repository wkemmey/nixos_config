{
  "chat.editor.fontFamily": "JetBrains Mono",
  "chat.editor.fontSize": 16,
  "chat.fontFamily": "Montserrat",
  "debug.console.fontFamily": "JetBrains Mono",
  "debug.console.fontSize": 16,
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 16,
  "editor.codeLensFontStyle": "italic",
  "editor.inlineSuggest.fontFamily": "JetBrains Mono",
  "editor.inlayHints.fontSize": 11,
  "editor.minimap.sectionHeaderFontSize": 10,
  "markdown.preview.fontFamily": "Montserrat",
  "markdown.preview.fontSize": 16,
  "notebook.markup.fontFamily": "Montserrat",
  "scm.inputFontFamily": "JetBrains Mono",
  "scm.inputFontSize": 15,
  "screencastMode.fontSize": 64,
  "terminal.integrated.fontSize": 16,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "update.mode": "none",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/run/current-system/sw/bin/bash"
    }
  },
  "terminal.integrated.automationProfile.linux": {
    "path": "/run/current-system/sw/bin/bash"
  },
  "files.readonlyInclude": {
    "**/.cargo/registry/src/**/*.rs": true,
    "**/.cargo/git/checkouts/**/*.rs": true,
    "**/lib/rustlib/src/rust/library/**/*.rs": true
  },
  "specstory.cloudSync.enabled": "never",
  "specstory.helpUsImprove": false,
  "workbench.colorCustomizations": {
    "focusBorder": "#50dbd0",
    "foreground": "#dbe4ed",
    "editor.background": "#0c141b",
    "editor.foreground": "#dbe4ed",
    "editorLineNumber.foreground": "#b7c9d8",
    "editorLineNumber.activeForeground": "#50dbd0",
    "editorCursor.foreground": "#50dbd0",
    "editor.selectionBackground": "#00504b80",
    "editor.inactiveSelectionBackground": "#38495660",
    "sideBar.background": "#182127",
    "sideBar.foreground": "#dbe4ed",
    "sideBar.border": "#8193a2",
    "sideBarTitle.foreground": "#dbe4ed",
    "sideBarSectionHeader.background": "#222b32",
    "sideBarSectionHeader.foreground": "#dbe4ed",
    "activityBar.background": "#182127",
    "activityBar.foreground": "#dbe4ed",
    "activityBar.inactiveForeground": "#b7c9d8",
    "activityBar.activeBorder": "#50dbd0",
    "activityBarBadge.background": "#50dbd0",
    "activityBarBadge.foreground": "#003734",
    "statusBar.background": "#141d23",
    "statusBar.foreground": "#dbe4ed",
    "statusBar.border": "#8193a2",
    "statusBar.noFolderBackground": "#141d23",
    "titleBar.activeBackground": "#182127",
